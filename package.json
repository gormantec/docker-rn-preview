{
  "name": "docker-rn-preview",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:image": "iot build start --push --no-deploy",
    "build:image-force": "iot build start --bump-version --push --recreate --follow --read-env --sync-secrets",
    "build:push": "docker build -t ghcr.io/gormantec/docker-rn-preview:latest . && docker push ghcr.io/gormantec/docker-rn-preview:latest"
  },
  "devDependencies": {
    "@gormantec/iot-cli": "^1.0.23"
  }
}
